# Banco criado pelo Docker Compose
POSTGRES_PASSWORD=
POSTGRES_PORT=5437
APP_PORT=8088

# Gere cada segredo separadamente com: openssl rand -hex 32
JWT_SECRET=
MFA_ENCRYPTION_KEY=

# Primeiro administrador (usado somente quando não existe nenhum admin)
BOOTSTRAP_ADMIN_LOGIN=99999999999
BOOTSTRAP_ADMIN_PASSWORD=

# Nunca ative em produção. O compose de demonstração substitui para true.
DEMO_USERS_ENABLED=false

# Endereços aceitos pela API. Em produção, use HTTPS e a origem exata.
FRONTEND_URL=http://localhost:8088
CORS_ORIGINS=http://localhost:8088

# Compatibilidade legada com Gemini. Para novas instalações, configure o provedor pelo frontend do superadmin.
GEMINI_API_KEY=

# Recuperação de senha por e-mail (SMTP). Sem SMTP_HOST e SMTP_FROM o recurso fica desativado.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="NUVYO <nao-responda@seudominio.com>"
