# Database Configuration
# Se DATABASE_URL estiver preenchida, ela substitui os campos DB_* abaixo.
DATABASE_URL=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_BASE64=
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT_MS=10000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=central_atividades
DB_USER=postgres
DB_PASSWORD=use_uma_senha_aleatoria_forte

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Gere com: openssl rand -hex 32
JWT_SECRET=
MFA_ENCRYPTION_KEY=

# Usados apenas quando ainda não existe nenhum administrador
BOOTSTRAP_ADMIN_LOGIN=
BOOTSTRAP_ADMIN_PASSWORD=

# Somente para demonstração local; a API recusa esta opção em produção.
DEMO_USERS_ENABLED=false

# Integração opcional com IA
GEMINI_API_KEY=
