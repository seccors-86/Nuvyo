{
  "name": "nuvyo-api",
  "version": "1.0.0",
  "description": "Backend API for NUVYO - Gestão Inteligente",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node -r dotenv/config src/migrations/run.js",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
